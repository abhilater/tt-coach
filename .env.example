# SQLite database path (relative to cwd or absolute)
DATABASE_URL=sqlite:///./data/tt_coach.sqlite3

# Logging
LOG_LEVEL=INFO

# YouTube Data API v3 (optional but recommended for discovery)
YOUTUBE_API_KEY=

# Local paths
DATA_DIR=./data
FACE_INDEX_PATH=./data/faces.faiss
FACE_META_PATH=./data/faces_meta.json

# Whisper (CPU-friendly defaults)
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# LLM routing: ollama | gemini | openai (ollama-only local dev avoids Gemini quota)
LLM_SUMMARY=ollama
LLM_INSIGHTS=ollama
LLM_TAGGING=ollama

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

GEMINI_API_KEY=
OPENAI_API_KEY=

# Scheduler (cron-style hour/minute, server local time)
SCHEDULER_REFRESH_HOUR=6
SCHEDULER_REFRESH_MINUTE=0

# Cap analyze + coach-match per scheduled run (cost control)
MAX_PIPELINE_VIDEOS=15

# Related-video discovery (yt-dlp scrape, 1 hop)
RELATED_PER_SEED=8
RELATED_TOTAL_CAP=200

# Admission gate: cosine similarity to enrolled coach faces (InsightFace buffalo_s).
# Tune with FACE_MATCH_FRAME_HIT_QUORUM; threshold-only tightening can wipe the feed if all top-k neighbors sit below it on real footage.
PREFERRED_COACH_MIN_CONFIDENCE=0.55

# Face-match hardening
FACE_MIN_DET_SCORE=0.6
FACE_MATCH_FRAMES=16
# Frames that must independently clear PREFERRED_COACH_MIN_CONFIDENCE for the same coach
FACE_MATCH_FRAME_HIT_QUORUM=1
